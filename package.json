    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.1"
